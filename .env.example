# Ports
API_PORT=8000
WEB_PORT=3000

# Frontend → API
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# API CORS (comma-separated browser origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional AI layer. Podscope works fully without it.
# Supported values: none | openai | anthropic | local
AI_PROVIDER=none
# Provide a key only if AI_PROVIDER is not "none". Never commit real keys.
AI_API_KEY=
AI_MODEL=
